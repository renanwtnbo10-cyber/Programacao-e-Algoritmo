programa {
  funcao inicio() {
    inteiro num1
    inteiro num2
    inteiro num3

    escreva("Escreva seu primeiro número: ")
    leia(num1)

    escreva("Escreva seu segundo número: ")
    leia(num2)

    escreva("Escreva seu terceiro número: ")
    leia(num3)

    inteiro resultado = num1 + num2 + num3

    escreva("O resultado da soma é: ", resultado)

  }
}
